{
  "log": {
    "entries": [
      {
        "request": {
          "url": "https://example.com/api?tabId=tab-123&token=secret",
          "headers": [
            {
              "name": "Authorization",
              "value": "Bearer super-secret"
            },
            {
              "name": "X-Trace",
              "value": "keep-me"
            }
          ],
          "cookies": [
            {
              "name": "session",
              "value": "cookie-secret"
            }
          ],
          "postData": {
            "mimeType": "application/json",
            "text": "{\"accountNumber\":\"123-45\",\"name\":\"Kim\",\"note\":\"safe\"}"
          }
        },
        "response": {
          "headers": [
            {
              "name": "Set-Cookie",
              "value": "session=abc"
            }
          ],
          "cookies": [
            {
              "name": "session",
              "value": "abc"
            }
          ],
          "content": {
            "text": "Bearer another-secret"
          }
        }
      }
    ]
  }
}

